use mach.int.Int

type t_Ordering = Less | Equal | Greater

function cmp_log_Int (self: int) (o: int) : t_Ordering = [%#sord'12] if Int.(<) self o then
    Less
  else
    if self = o then Equal else Greater


function eq_cmp_Int (x: int) (y: int) : ()

axiom eq_cmp_Int_spec: forall x: int, y: int. [%#sord'11] (x = y) = (cmp_log_Int x y = Equal)

function antisym2_Int (x: int) (y: int) : ()

axiom antisym2_Int_spec: forall x: int, y: int. ([%#sord'9] cmp_log_Int x y = Greater)
    -> ([%#sord'10] cmp_log_Int y x = Less)

function antisym1_Int (x: int) (y: int) : ()

axiom antisym1_Int_spec: forall x: int, y: int. ([%#sord'7] cmp_log_Int x y = Less)
    -> ([%#sord'8] cmp_log_Int y x = Greater)

function trans_Int (x: int) (y: int) (z: int) (o: t_Ordering) : ()

axiom trans_Int_spec: forall x: int, y: int, z: int, o: t_Ordering. ([%#sord'4] cmp_log_Int x y = o)
    -> ([%#sord'5] cmp_log_Int y z = o) -> ([%#sord'6] cmp_log_Int x z = o)

function refl_Int (x: int) : ()

axiom refl_Int_spec: forall x: int. [%#sord'3] cmp_log_Int x x = Equal

function cmp_gt_log_Int (x: int) (y: int) : ()

axiom cmp_gt_log_Int_spec: forall x: int, y: int. [%#sord'2] Int.(>) x y = (cmp_log_Int x y = Greater)

function cmp_ge_log_Int (x: int) (y: int) : ()

axiom cmp_ge_log_Int_spec: forall x: int, y: int. [%#sord'1] Int.(>=) x y = (cmp_log_Int x y <> Less)

function cmp_lt_log_Int (x: int) (y: int) : ()

axiom cmp_lt_log_Int_spec: forall x: int, y: int. [%#sord'0] Int.(<) x y = (cmp_log_Int x y = Less)

function cmp_le_log_Int (x: int) (y: int) : ()

axiom cmp_le_log_Int_spec: forall x: int, y: int. [%#sord] Int.(<=) x y = (cmp_log_Int x y <> Greater)

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

