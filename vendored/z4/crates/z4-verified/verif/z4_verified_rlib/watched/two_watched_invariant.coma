predicate two_watched_invariant [#"./z4/crates/z4-verified/src/watched.rs" 29 0 29 71] (clause_len: int) (num_watches: int)

goal vc_two_watched_invariant: ([%#swatched] Int.(>=) clause_len 2)
  -> ([%#swatched'0] num_watches = 2) -> ([@expl:two_watched_invariant ensures] [%#swatched'1] num_watches = 2)
