(* #"./z4/crates/z4-verified/src/watched.rs" 161 0 166 9 *)

let%span swatched = "./z4/crates/z4-verified/src/watched.rs" 157 11 157 27
let%span swatched'0 = "./z4/crates/z4-verified/src/watched.rs" 158 11 158 35
let%span swatched'1 = "./z4/crates/z4-verified/src/watched.rs" 159 11 159 45
let%span swatched'2 = "./z4/crates/z4-verified/src/watched.rs" 160 10 160 26
let%span swatched'3 = "./z4/crates/z4-verified/src/watched.rs" 167 4 167 8

use mach.int.Int

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

constant old_watches : int

constant new_watches : int

constant removed_one : bool

constant added_one : bool

predicate replacement_preserves_two_watched [#"./z4/crates/z4-verified/src/watched.rs" 161 0 166 9] (old_watches: int) (new_watches: int) (removed_one: bool) (added_one: bool)

goal vc_replacement_preserves_two_watched: ([%#swatched] old_watches = 2)
  -> ([%#swatched'0] removed_one /\ added_one)
  -> ([%#swatched'1] new_watches = Int.(+) (Int.(-) old_watches 1) 1)
  -> ([@expl:replacement_preserves_two_watched ensures] [%#swatched'2] new_watches = 2)
