% Jobshop scheduling: 2 jobs, 3 machines.
% Job 1: M1(3) -> M2(2) -> M3(4)
% Job 2: M2(2) -> M1(3) -> M3(1)
% Minimize makespan.
% Tests: int_lin_le, int_lin_eq, cumulative, optimization

% Start times (horizon 0..15)
var 0..15: s11 :: output_var;
var 0..15: s12 :: output_var;
var 0..15: s13 :: output_var;
var 0..15: s21 :: output_var;
var 0..15: s22 :: output_var;
var 0..15: s23 :: output_var;
var 0..15: makespan :: output_var;

% Precedence: job 1: s11+3 <= s12, s12+2 <= s13
constraint int_lin_le([1, -1], [s11, s12], -3);
constraint int_lin_le([1, -1], [s12, s13], -2);

% Precedence: job 2: s21+2 <= s22, s22+3 <= s23
constraint int_lin_le([1, -1], [s21, s22], -2);
constraint int_lin_le([1, -1], [s22, s23], -3);

% Machine disjunctive: M1 has s11(dur 3) and s22(dur 3)
% Either s11+3 <= s22 or s22+3 <= s11
% Encode with a bool decision variable
var 0..1: b_m1 :: output_var;
% Big-M encoding: s11 - s22 <= -3 + 20*b_m1 => s11 - s22 - 20*b_m1 <= -3
constraint int_lin_le([1, -1, -20], [s11, s22, b_m1], -3);
% s22 - s11 <= -3 + 20*(1-b_m1) = 17 - 20*b_m1 => s22 - s11 + 20*b_m1 <= 17
constraint int_lin_le([-1, 1, 20], [s11, s22, b_m1], 17);

% Machine disjunctive: M2 has s12(dur 2) and s21(dur 2)
var 0..1: b_m2 :: output_var;
constraint int_lin_le([1, -1, -20], [s12, s21, b_m2], -2);
constraint int_lin_le([-1, 1, 20], [s12, s21, b_m2], 18);

% Machine disjunctive: M3 has s13(dur 4) and s23(dur 1)
var 0..1: b_m3 :: output_var;
constraint int_lin_le([1, -1, -20], [s13, s23, b_m3], -4);
constraint int_lin_le([-1, 1, 20], [s13, s23, b_m3], 19);

% Makespan: makespan >= s13 + 4, makespan >= s23 + 1
constraint int_lin_le([1, -1], [s13, makespan], -4);
constraint int_lin_le([1, -1], [s23, makespan], -1);

solve minimize makespan;
