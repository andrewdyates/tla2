% Element constraint: result = arr[index].
% Tests: array_int_element
var 1..4: index :: output_var;
var 10..40: result :: output_var;
int: a1 = 10;
int: a2 = 20;
int: a3 = 30;
int: a4 = 40;
array [1..4] of int: arr = [a1, a2, a3, a4];

constraint array_int_element(index, arr, result);
constraint int_eq(index, 3);

solve satisfy;
