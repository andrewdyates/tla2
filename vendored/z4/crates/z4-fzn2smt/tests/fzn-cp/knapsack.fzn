% Simple knapsack: maximize value subject to weight constraint.
% 5 items, each 0 or 1 (binary knapsack).
% weights: [3, 4, 2, 5, 1], values: [4, 5, 3, 7, 1], capacity: 10
var 0..1: x1 :: output_var;
var 0..1: x2 :: output_var;
var 0..1: x3 :: output_var;
var 0..1: x4 :: output_var;
var 0..1: x5 :: output_var;
var 0..20: obj :: output_var;

% Weight constraint: 3*x1 + 4*x2 + 2*x3 + 5*x4 + 1*x5 <= 10
constraint int_lin_le([3, 4, 2, 5, 1], [x1, x2, x3, x4, x5], 10);

% Objective: obj = 4*x1 + 5*x2 + 3*x3 + 7*x4 + 1*x5
constraint int_lin_eq([4, 5, 3, 7, 1, -1], [x1, x2, x3, x4, x5, obj], 0);

solve maximize obj;
