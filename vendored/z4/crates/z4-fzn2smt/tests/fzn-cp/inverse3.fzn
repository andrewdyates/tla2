% 3-element inverse constraint: x[y[i]] = i for all i.
% Tests: inverse constraint
var 1..3: x1 :: output_var;
var 1..3: x2 :: output_var;
var 1..3: x3 :: output_var;
var 1..3: y1 :: output_var;
var 1..3: y2 :: output_var;
var 1..3: y3 :: output_var;
array [1..3] of var int: x = [x1, x2, x3];
array [1..3] of var int: y = [y1, y2, y3];

constraint fzn_inverse(x, y);

solve satisfy;
