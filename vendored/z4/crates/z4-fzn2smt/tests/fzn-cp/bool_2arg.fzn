% Test 2-arg bool_and, bool_or, bool_xor (no result variable).
% bool_and(a,b) = assert a AND b
% bool_or(c,d) = assert c OR d
% bool_xor(e,f) = assert e != f
var bool: a :: output_var;
var bool: b :: output_var;
var bool: c :: output_var;
var bool: d :: output_var;
var bool: e :: output_var;
var bool: f :: output_var;

constraint bool_and(a, b);
constraint bool_or(c, d);
constraint bool_xor(e, f);
constraint bool_not(c, d);

solve satisfy;
