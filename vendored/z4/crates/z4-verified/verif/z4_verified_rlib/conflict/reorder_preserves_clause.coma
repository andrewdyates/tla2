predicate reorder_preserves_clause [#"./z4/crates/z4-verified/src/conflict.rs" 156 0 160 9] (old_len: int) (new_len: int) (is_permutation: bool)

goal vc_reorder_preserves_clause: ([%#sconflict] old_len = new_len)
