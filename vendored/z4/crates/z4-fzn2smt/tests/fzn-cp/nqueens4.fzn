% 4-queens problem: place 4 queens on a 4x4 board, no attacks.
% Tests: alldifferent_int, int_lin_ne
var 1..4: q1 :: output_var;
var 1..4: q2 :: output_var;
var 1..4: q3 :: output_var;
var 1..4: q4 :: output_var;
array [1..4] of var int: q = [q1, q2, q3, q4];

% All queens in different columns
constraint alldifferent_int(q);

% No two queens on same diagonal (i-j != qi-qj and i+j != qi+qj)
% q1-q2 != 1-2 = -1, so q1-q2 != -1 and q1-q2 != 1
% Encoded as int_lin_ne: 1*q1 + (-1)*q2 != k for each pair/diagonal
constraint int_lin_ne([1, -1], [q1, q2], 1);
constraint int_lin_ne([1, -1], [q1, q2], -1);
constraint int_lin_ne([1, -1], [q1, q3], 2);
constraint int_lin_ne([1, -1], [q1, q3], -2);
constraint int_lin_ne([1, -1], [q1, q4], 3);
constraint int_lin_ne([1, -1], [q1, q4], -3);
constraint int_lin_ne([1, -1], [q2, q3], 1);
constraint int_lin_ne([1, -1], [q2, q3], -1);
constraint int_lin_ne([1, -1], [q2, q4], 2);
constraint int_lin_ne([1, -1], [q2, q4], -2);
constraint int_lin_ne([1, -1], [q3, q4], 1);
constraint int_lin_ne([1, -1], [q3, q4], -1);

solve satisfy;
