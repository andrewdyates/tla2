% Graph coloring: 5-node graph with 3 colors
% Petersen-like graph structure
% Tests: int_ne, domain constraints
var 1..3: c1 :: output_var;
var 1..3: c2 :: output_var;
var 1..3: c3 :: output_var;
var 1..3: c4 :: output_var;
var 1..3: c5 :: output_var;

% Edges: (1,2), (1,3), (2,3), (2,4), (3,5), (4,5)
constraint int_ne(c1, c2);
constraint int_ne(c1, c3);
constraint int_ne(c2, c3);
constraint int_ne(c2, c4);
constraint int_ne(c3, c5);
constraint int_ne(c4, c5);

solve satisfy;
