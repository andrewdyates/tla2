<?xml version="1.0"?>
<!-- 3-node token ring.
     Places: p0, p1, p2 (token at node i means node i holds the token).
     Transitions: t0 (p0->p1), t1 (p1->p2), t2 (p2->p0).
     Initial: p0=1, p1=0, p2=0.
     Properties: deadlock-free (cyclic), 1-safe, all transitions quasi-live.
     State space: 3 states, 3 edges. Max token in place: 1. Max token sum: 1.
-->
<pnml xmlns="http://www.pnml.org/version-2009/grammar/pnml">
  <net id="TokenRing" type="http://www.pnml.org/version-2009/grammar/ptnet">
    <name><text>TokenRing</text></name>
    <page id="page0">
      <!-- Places -->
      <place id="p0">
        <name><text>p0</text></name>
        <initialMarking><text>1</text></initialMarking>
      </place>
      <place id="p1">
        <name><text>p1</text></name>
      </place>
      <place id="p2">
        <name><text>p2</text></name>
      </place>

      <!-- Transitions -->
      <transition id="t0"><name><text>t0</text></name></transition>
      <transition id="t1"><name><text>t1</text></name></transition>
      <transition id="t2"><name><text>t2</text></name></transition>

      <!-- Arcs: t0 moves token from p0 to p1 -->
      <arc id="a1" source="p0" target="t0"/>
      <arc id="a2" source="t0" target="p1"/>

      <!-- Arcs: t1 moves token from p1 to p2 -->
      <arc id="a3" source="p1" target="t1"/>
      <arc id="a4" source="t1" target="p2"/>

      <!-- Arcs: t2 moves token from p2 to p0 -->
      <arc id="a5" source="p2" target="t2"/>
      <arc id="a6" source="t2" target="p0"/>
    </page>
  </net>
</pnml>
