(* #"./z4/crates/z4-verified/src/conflict.rs" 126 0 131 9 *)

let%span sconflict = "./z4/crates/z4-verified/src/conflict.rs" 121 11 121 19
let%span sconflict'0 = "./z4/crates/z4-verified/src/conflict.rs" 122 11 122 19
let%span sconflict'1 = "./z4/crates/z4-verified/src/conflict.rs" 123 11 123 31
let%span sconflict'2 = "./z4/crates/z4-verified/src/conflict.rs" 124 11 124 76
let%span sconflict'3 = "./z4/crates/z4-verified/src/conflict.rs" 125 10 125 25
let%span sconflict'4 = "./z4/crates/z4-verified/src/conflict.rs" 132 4 132 8

meta "compute_max_steps" 1000000

meta "select_lsinst" "all"

constant c1_valid : bool

constant c2_valid : bool

constant resolvent_from_c1_c2 : bool

constant resolvent_valid : bool

predicate resolution_preserves_implication [#"./z4/crates/z4-verified/src/conflict.rs" 126 0 131 9] (c1_valid: bool) (c2_valid: bool) (resolvent_from_c1_c2: bool) (resolvent_valid: bool)

goal vc_resolution_preserves_implication: ([%#sconflict] c1_valid)
  -> ([%#sconflict'0] c2_valid)
  -> ([%#sconflict'1] resolvent_from_c1_c2)
  -> ([%#sconflict'2] resolvent_valid = (c1_valid /\ c2_valid /\ resolvent_from_c1_c2))
  -> ([@expl:resolution_preserves_implication ensures] [%#sconflict'3] resolvent_valid)
